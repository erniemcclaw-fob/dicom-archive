        </mxCell>
        <!-- ═══════════════ ARROWS ═══════════════ -->
        <!-- Modality → Agent (DICOM C-STORE) -->
        <mxCell id="arrow1" value="C-STORE (DICOM)&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;No TLS&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="modality" target="agent_scp" parent="1">
