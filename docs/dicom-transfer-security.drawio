          <mxGeometry x="330" y="285" width="180" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r_step1" value="&lt;b&gt;① Request Upload URL&lt;/b&gt;&lt;br&gt;POST /ingest/prepare&lt;br&gt;+ X-Api-Key header&lt;br&gt;Sends DICOM metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="r1">
