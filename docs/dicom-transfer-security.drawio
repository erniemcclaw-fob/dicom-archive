        <mxCell id="server_internal" value="&lt;b&gt;/internal/* Endpoints&lt;/b&gt;&lt;br&gt;POST /internal/register&lt;br&gt;POST /internal/heartbeat&lt;br&gt;POST /internal/routed&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;NO AUTH — accepts any caller&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
