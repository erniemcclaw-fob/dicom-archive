        <mxCell id="r_leg1" value="&lt;font color=&quot;#28a745&quot;&gt;✓&lt;/font&gt; Agent is edge device on LAN — no DB access, no cloud storage creds" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="r1">
