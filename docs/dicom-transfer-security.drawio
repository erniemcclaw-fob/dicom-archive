  </diagram>
  <diagram id="current-state" name="Current Architecture — Edge Agent + Server-Proxied Upload">
    <mxGraphModel dx="1234" dy="878" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="r0" />
        <mxCell id="r1" parent="r0" />
        <mxCell id="r_title" parent="r1" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" value="DICOM Archive — Current: Edge Agent + Server-Proxied Upload (3-Step Handshake)" vertex="1">
          <mxGeometry height="40" width="1000" x="250" y="15" as="geometry" />
        </mxCell>
        <mxCell id="r_zone_local" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;verticalAlign=top;fontStyle=1;fontSize=14;arcSize=6;" value="Local Site (Hospital / Clinic LAN)" vertex="1">
          <mxGeometry height="580" width="520" x="40" y="70" as="geometry" />
        </mxCell>
        <mxCell id="r_modality" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;Modality / PACS&lt;/b&gt;&lt;br&gt;(MG, CT, MR, etc.)" vertex="1">
          <mxGeometry height="50" width="150" x="70" y="140" as="geometry" />
        </mxCell>
        <mxCell id="r_agent_box" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f0fa;strokeColor=#9673a6;verticalAlign=top;arcSize=6;" value="" vertex="1">
          <mxGeometry height="380" width="480" x="60" y="240" as="geometry" />
        </mxCell>
        <mxCell id="r_agent_title" parent="r1" style="text;html=1;fontSize=12;align=center;" value="&lt;b&gt;Edge Agent&lt;/b&gt;  (Python, LAN device, :11112)&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;No DB access | No cloud storage credentials&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="400" x="100" y="248" as="geometry" />
        </mxCell>
        <mxCell id="r_agent_scp" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;C-STORE SCP&lt;/b&gt;&lt;br&gt;pynetdicom (no TLS needed on LAN)" vertex="1">
          <mxGeometry height="40" width="220" x="80" y="290" as="geometry" />
        </mxCell>
        <mxCell id="r_agent_validate" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;Validate &amp; SHA-256&lt;/b&gt;&lt;br&gt;Check UIDs, PixelData, checksum" vertex="1">
          <mxGeometry height="40" width="220" x="80" y="340" as="geometry" />
        </mxCell>
        <mxCell id="r_agent_local" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;Local Staging&lt;/b&gt;&lt;br&gt;Save .dcm to local disk&lt;br&gt;(temporary — deleted after upload)" vertex="1">
          <mxGeometry height="50" width="220" x="80" y="390" as="geometry" />
        </mxCell>
        <mxCell id="r_upload_engine" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;verticalAlign=top;arcSize=8;" value="" vertex="1">
          <mxGeometry height="310" width="200" x="320" y="290" as="geometry" />
        </mxCell>
        <mxCell id="r_upload_title" parent="r1" style="text;html=1;fontSize=11;align=center;fontColor=#28a745;" value="&lt;b&gt;Upload Engine&lt;/b&gt;&lt;br&gt;(asyncio, N parallel workers)" vertex="1">
          <mxGeometry height="30" width="180" x="330" y="295" as="geometry" />
        </mxCell>
        <mxCell id="r_step1" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" value="&lt;b&gt;① Prepare&lt;/b&gt;&lt;br&gt;POST /ingest/prepare&lt;br&gt;X-Api-Key: {secret}&lt;br&gt;Body: DICOM metadata" vertex="1">
          <mxGeometry height="60" width="170" x="335" y="330" as="geometry" />
        </mxCell>
        <mxCell id="r_step2" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" value="&lt;b&gt;② Upload&lt;/b&gt;&lt;br&gt;PUT /ingest/upload/{id}&lt;br&gt;X-Api-Key: {secret}&lt;br&gt;Body: raw .dcm bytes&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;Parallel (N workers)&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="170" x="335" y="400" as="geometry" />
        </mxCell>
        <mxCell id="r_step3" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" value="&lt;b&gt;③ Confirm&lt;/b&gt;&lt;br&gt;POST /ingest/confirm&lt;br&gt;Body: instance_id, sha256" vertex="1">
          <mxGeometry height="50" width="170" x="335" y="480" as="geometry" />
        </mxCell>
        <mxCell id="r_cleanup" parent="r1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" value="&lt;b&gt;④ Cleanup&lt;/b&gt;&lt;br&gt;Delete local staging file" vertex="1">
          <mxGeometry height="35" width="170" x="335" y="540" as="geometry" />
        </mxCell>
        <mxCell id="r_af1" edge="1" parent="r1" source="r_agent_scp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#9673a6;" target="r_agent_validate">
