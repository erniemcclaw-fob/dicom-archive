        </mxCell>

        <mxCell id="r_agent_scp" value="&lt;b&gt;C-STORE SCP&lt;/b&gt;&lt;br&gt;pynetdicom (no TLS needed on LAN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="r1">
          <mxGeometry x="80" y="280" width="220" height="40" as="geometry" />
