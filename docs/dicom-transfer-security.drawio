        <mxCell id="r_rogue_block" value="&lt;font color=&quot;#cc0000&quot;&gt;✗ BLOCKED&lt;br&gt;No API key&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#cc0000;dashed=1;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;" edge="1" source="r_rogue" target="r_server_auth" parent="r1">
