        </mxCell>
        <mxCell id="legend4" value="&lt;font color=&quot;#b85450&quot;&gt;4.&lt;/font&gt; PostgreSQL port 5432 exposed externally" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="50" y="613" width="260" height="16" as="geometry" />
        </mxCell>
        <mxCell id="legend5" value="&lt;font color=&quot;#b85450&quot;&gt;5.&lt;/font&gt; Compromised agent = full DB + storage access" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="1">
