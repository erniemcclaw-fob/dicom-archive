          <mxGeometry x="335" y="460" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_cleanup" value="&lt;b&gt;④ Cleanup&lt;/b&gt;&lt;br&gt;Delete local staging file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="r1">
          <mxGeometry x="335" y="518" width="170" height="35" as="geometry" />
