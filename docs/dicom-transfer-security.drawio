        </mxCell>
        <!-- ─── PostgreSQL ─── -->
        <mxCell id="postgres" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;dicom_archive&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Port 5432 exposed&lt;br&gt;Both server AND agent connect&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="470" width="160" height="100" as="geometry" />
        </mxCell>
        <!-- ─── Blob Storage ─── -->
        <mxCell id="blob" value="&lt;b&gt;Blob Storage&lt;/b&gt;&lt;br&gt;Local FS / S3 / Azure" style="shape=mxgraph.aws3.s3;html=1;fillColor=#E05243;strokeColor=none;fontSize=11;fontColor=#FFFFFF;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="990" y="480" width="60" height="60" as="geometry" />
        </mxCell>
        <!-- ─── Downstream PACS ─── -->
        <mxCell id="downstream" value="&lt;b&gt;Downstream&lt;/b&gt;&lt;br&gt;PACS / Workstation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
