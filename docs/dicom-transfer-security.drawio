        </mxCell>
        <mxCell id="agent_store" value="&lt;b&gt;Store to Blob&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Agent has full S3/Azure creds&lt;/font&gt;&lt;br&gt;Path: YYYYMMDD/study/series/inst.dcm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
