        </mxCell>
        <!-- Agent → PostgreSQL -->
        <mxCell id="arrow3" value="psycopg2&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Direct connection&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=1;strokeColor=#d6b656;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="agent_index" target="postgres" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Server → PostgreSQL -->
        <mxCell id="arrow4" value="EF Core" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=1;strokeColor=#d6b656;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="server_api" target="postgres" parent="1">
