        </mxCell>
        <mxCell id="legend6" value="&lt;font color=&quot;#b85450&quot;&gt;6.&lt;/font&gt; Synchronous storage — no parallel uploads" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="50" y="645" width="260" height="16" as="geometry" />
        </mxCell>
