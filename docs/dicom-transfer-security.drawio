        </mxCell>
        <mxCell id="server_wado" value="&lt;b&gt;WADO-RS&lt;/b&gt;&lt;br&gt;File retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
