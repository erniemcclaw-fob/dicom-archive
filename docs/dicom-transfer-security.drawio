        </mxCell>
        <mxCell id="r_leg2" value="&lt;font color=&quot;#28a745&quot;&gt;✓&lt;/font&gt; Pre-signed URLs: agent uploads direct to blob (server not in data path)" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="r1">
