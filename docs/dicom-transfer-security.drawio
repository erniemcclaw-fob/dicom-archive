        </mxCell>

        <mxCell id="r_server_prepare" value="&lt;b&gt;POST /ingest/prepare&lt;/b&gt;&lt;br&gt;1. Upserts patient/exam/series/instance&lt;br&gt;2. Generates SAS token / pre-signed URL&lt;br&gt;3. Returns upload URL + instance ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="r1">
          <mxGeometry x="740" y="215" width="270" height="65" as="geometry" />
        </mxCell>

        <mxCell id="r_server_confirm" value="&lt;b&gt;POST /ingest/confirm&lt;/b&gt;&lt;br&gt;1. Verifies blob exists in storage&lt;br&gt;2. Marks instance as &quot;stored&quot;&lt;br&gt;3. Triggers routing engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="r1">
          <mxGeometry x="740" y="290" width="270" height="65" as="geometry" />
        </mxCell>

