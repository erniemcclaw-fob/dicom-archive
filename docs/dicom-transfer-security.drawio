        <!-- Router → Downstream PACS -->
        <mxCell id="arrow7" value="C-STORE SCU&lt;br&gt;(forwarding)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#6c8ebf;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" source="server_router" target="downstream" parent="1">
