        </mxCell>
        <mxCell id="legend1" value="&lt;font color=&quot;#b85450&quot;&gt;1.&lt;/font&gt; Agent had full database credentials (psycopg2)" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="1">
