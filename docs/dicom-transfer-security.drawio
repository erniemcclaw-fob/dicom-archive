        </mxCell>
        <mxCell id="r_leg4" value="&lt;font color=&quot;#28a745&quot;&gt;✓&lt;/font&gt; API Key auth blocks rogue agents — only the ① and ③ control calls need it" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="r1">
