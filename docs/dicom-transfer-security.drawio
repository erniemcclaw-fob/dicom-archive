        </mxCell>
        <mxCell id="r_leg5" value="&lt;font color=&quot;#28a745&quot;&gt;✓&lt;/font&gt; 3-step handshake: prepare → upload → confirm (tracks failed uploads)" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="r1">
