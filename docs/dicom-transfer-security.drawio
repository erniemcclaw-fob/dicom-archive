        </mxCell>
        <mxCell id="legend3" value="&lt;font color=&quot;#b85450&quot;&gt;3.&lt;/font&gt; /internal/* endpoints accepted any caller — no auth" style="text;html=1;fontSize=10;align=left;spacingLeft=4;" vertex="1" parent="1">
