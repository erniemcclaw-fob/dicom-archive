        </mxCell>

        <mxCell id="r_step2" value="&lt;b&gt;② Upload .dcm&lt;/b&gt;&lt;br&gt;PUT to pre-signed URL&lt;br&gt;Direct to blob storage&lt;br&gt;&lt;font color=&quot;#28a745&quot;&gt;✓ Parallel (N workers)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="r1">
          <mxGeometry x="335" y="390" width="170" height="60" as="geometry" />
        </mxCell>

