# ── SCP (this agent) ──────────────────────────────────
AE_TITLE=ARCHIVE_SCP
LISTEN_PORT=11112
LISTEN_HOST=0.0.0.0

# ── Storage backend: "s3" | "azure" | "local" ─────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./received

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=dicom-archive

# Azure Blob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER=dicom-archive

# ── Postgres ──────────────────────────────────────────
# Leave blank to skip DB (file-only mode)
DATABASE_URL=postgresql://user:password@localhost:5432/dicom_archive

# ── Behaviour ─────────────────────────────────────────
# Quarantine folder for files that fail validation
QUARANTINE_PATH=./quarantine
# Max file size accepted (bytes) — 0 = unlimited
MAX_FILE_BYTES=0
# Server URL for immediate routing notification (optional).
# Leave blank to use the server's 30-second background queue only.
ROUTER_URL=http://localhost:8080
