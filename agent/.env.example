# ── SCP (this agent) ──────────────────────────────────
AE_TITLE=ARCHIVE_SCP
LISTEN_PORT=11112
LISTEN_HOST=0.0.0.0

# ── Server connection ────────────────────────────────
# URL of the cloud server's API
SERVER_URL=http://localhost:8080
# Shared secret — must match AGENT_API_KEY on the server
AGENT_API_KEY=change-me-to-a-strong-secret

# ── Upload engine ────────────────────────────────────
# Number of concurrent upload workers
UPLOAD_WORKERS=4
# Local staging directory for files awaiting upload
STAGING_PATH=./staging

# ── Behaviour ─────────────────────────────────────────
# Quarantine folder for files that fail validation
QUARANTINE_PATH=./quarantine
# Max file size accepted (bytes) — 0 = unlimited
MAX_FILE_BYTES=0
